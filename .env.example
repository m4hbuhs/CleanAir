# ── API Keys ──────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Cloud & Earth Engine ──────────────
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CREDENTIALS_PATH=path/to/serviceAccountKey.json

# Earth Engine Service Account Authentication (Optional but Recommended)
EE_SERVICE_ACCOUNT_JSON=path/to/earth_engine_service_account.json

# ── Model Configuration ──────────────────
XGBOOST_MODEL_PATH=cleanair_xgb_model.json
