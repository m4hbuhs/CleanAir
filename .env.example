# ── Primary API Keys (Required for Core Features) ──────────────────────────────
WAQI_API_TOKEN=your_waqi_api_token_here
GOOGLE_MAPS_GEOCODING_API_KEY=your_google_geocoding_api_key_here
GOOGLE_MAPS_HOTSPOT_API_KEY=your_google_maps_js_sdk_key_for_frontend_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Cloud & Firebase (Required for GCP Services) ──────────────
# Needed if running locally to access Firestore, Vision API, TTS, and STT
GOOGLE_APPLICATION_CREDENTIALS=path/to/firebase-service-account.json
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# ── Earth Engine Service Account Authentication (Optional) ──────────────
EE_SERVICE_ACCOUNT_JSON=path/to/earth_engine_service_account.json

# ── Legacy/External Location APIs (Optional) ──────────────────────────────
GEOAPIFY_KEY=your_geoapify_key_here
LOCATIONIQ_KEY=your_locationiq_key_here
IPINFO_KEY=your_ipinfo_key_here

# ── New Dependencies ──────────────────────────────
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here
REDIS_URL=redis://localhost:6379
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
